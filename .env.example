# ============================================================
# D&A Compliance Radar — environment variables
# Copy to .env and fill in. Never commit the real .env.
# ============================================================

# --- Core ---
ENVIRONMENT=development          # development | staging | production
DEBUG=true
JWT_SECRET=change-me-to-a-long-random-string-min-32-chars
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440

# --- Database ---
POSTGRES_USER=dacompliance
POSTGRES_PASSWORD=change-me
POSTGRES_DB=dacompliance
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
DATABASE_URL=postgresql+psycopg2://dacompliance:change-me@postgres:5432/dacompliance

# --- Redis / Celery ---
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# --- Companies House (required) ---
# Free key: https://developer.company-information.service.gov.uk
COMPANIES_HOUSE_API_KEY=
COMPANIES_HOUSE_BASE_URL=https://api.company-information.service.gov.uk
COMPANIES_HOUSE_STREAM_URL=https://stream.companieshouse.gov.uk

# --- OpenAI (optional — enables AI classification) ---
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# --- Alert channels (all optional, configure what you use) ---
# Slack: create an incoming webhook
SLACK_WEBHOOK_URL=

# Telegram: create a bot via @BotFather, get chat id
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Resend (transactional email)
RESEND_API_KEY=
ALERT_FROM_EMAIL=alerts@dennisandassociates.co.uk
ALERT_TO_EMAILS=team@dennisandassociates.co.uk

# --- Enrichment (optional) ---
GOOGLE_PLACES_API_KEY=
HUNTER_API_KEY=
APOLLO_API_KEY=
CLEARBIT_API_KEY=

# --- Intent monitoring (optional) ---
DATAFORSEO_LOGIN=
DATAFORSEO_PASSWORD=
SERPAPI_KEY=

# --- CRM (optional, pick one or more) ---
HUBSPOT_API_KEY=
PIPEDRIVE_API_TOKEN=
PIPEDRIVE_COMPANY_DOMAIN=
ZOHO_CLIENT_ID=
ZOHO_CLIENT_SECRET=

# --- Frontend ---
NEXT_PUBLIC_API_URL=http://localhost:8000

# --- Worker schedule overrides (optional, defaults sensible) ---
COMPANIES_HOUSE_POLL_INTERVAL_SECONDS=900
COMPLIANCE_SCAN_INTERVAL_SECONDS=3600
