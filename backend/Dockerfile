FROM python:3.12-slim

# --- Build-time env ---
ENV PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1 \
    PIP_NO_CACHE_DIR=1 \
    PIP_DISABLE_PIP_VERSION_CHECK=1

WORKDIR /app

# --- System deps (build-essential is needed only at install-time for some wheels) ---
RUN apt-get update && apt-get install -y --no-install-recommends \
        build-essential \
        libpq-dev \
        curl \
    && rm -rf /var/lib/apt/lists/*

# --- Python deps cached in their own layer ---
COPY requirements.txt .
RUN pip install --upgrade pip && pip install -r requirements.txt

# --- Non-root runtime user ---
# Creating before COPY so files end up with the right ownership.
ARG APP_UID=10001
ARG APP_GID=10001
RUN groupadd --system --gid $APP_GID app \
 && useradd  --system --uid $APP_UID --gid $APP_GID \
             --create-home --home-dir /home/app --shell /sbin/nologin app

# --- App source ---
COPY --chown=app:app . .

# Drop build-essential to shrink the image and remove the gcc/headers
# attack surface from the runtime image.
RUN apt-get purge -y --auto-remove build-essential \
 && rm -rf /var/lib/apt/lists/*

USER app

EXPOSE 8000

HEALTHCHECK --interval=30s --timeout=5s --start-period=20s --retries=3 \
    CMD curl -fsS http://localhost:8000/health || exit 1

CMD ["uvicorn", "app.main:app", "--host", "0.0.0.0", "--port", "8000"]
